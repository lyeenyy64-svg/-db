# ===========================================================
# DEBTFLOW Backend 환경변수
# 사용법: 이 파일을 .env 로 복사한 뒤 실제 값으로 채우세요.
#   PowerShell: Copy-Item backend/.env.example backend/.env
# ===========================================================

# Slack Bot User OAuth Token (xoxb- 로 시작하는 값)
SLACK_BOT_TOKEN=xoxb-여기에-실제-토큰-붙여넣기

# 모니터링할 Slack 채널 ID (C 로 시작하는 값)
# 찾는 법: Slack에서 #입금내역_공유방 → 채널 이름 클릭 → 맨 아래 "채널 ID" 복사
SLACK_CHANNEL_ID=C여기에-실제-채널ID-붙여넣기

# 폴링 주기 (분 단위) — 권장: 5
SLACK_POLL_INTERVAL_MINUTES=5
